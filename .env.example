# Copy this file to .env and fill in the key for the provider you use.
# Only the key matching the `llm` set in src/debate/config/agents.yaml is required.

# OpenAI (default)
OPENAI_API_KEY=

# Anthropic — if you switch the llm to anthropic/...
# ANTHROPIC_API_KEY=

# Google Gemini — if you switch the llm to gemini/...
# GEMINI_API_KEY=
